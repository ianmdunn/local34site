{
  "name": "@onwidget/astrowind",
  "version": "1.0.0-beta.52",
  "description": "AstroWind: A free template using Astro 5.0 and Tailwind CSS. Astro starter theme.",
  "type": "module",
  "private": true,
  "engines": {
    "node": "^18.17.1 || ^20.3.0 || >= 21.0.0"
  },
  "overrides": {
    "astro-compress": {
      "sharp": "0.34.3"
    }
  },
  "pnpm": {
    "shamefullyHoist": true
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--no-deprecation' astro dev",
    "start": "NODE_OPTIONS='--no-deprecation' astro dev",
    "build": "npm update && NODE_OPTIONS='--no-deprecation' astro build",
    "build:fast": "NODE_OPTIONS='--no-deprecation' astro build",
    "preview": "NODE_OPTIONS='--no-deprecation' astro preview",
    "astro": "astro",
    "check": "npm run check:astro && npm run check:eslint && npm run check:prettier",
    "check:astro": "NODE_OPTIONS='--no-deprecation' astro check",
    "check:eslint": "eslint .",
    "check:prettier": "prettier --check .",
    "fix": "npm run fix:eslint && npm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier -w .",
    "generate:favicons": "node scripts/generate-favicons.cjs",
    "upload:assets": "node scripts/upload-to-gcs.js",
    "upload:assets:dry": "node scripts/upload-to-gcs.js --dry-run",
    "upload:optimized": "node scripts/upload-optimized-to-gcs.js",
    "cleanup:dist": "node scripts/cleanup-dist-public.js",
    "build:gcs": "npm run build && npm run upload:assets && npm run upload:optimized && npm run cleanup:dist",
    "deploy": "npm run build:gcs"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@astrolib/analytics": "^0.6.1",
    "@astrolib/seo": "^1.0.0-beta.8",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.6",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "array-iterate": "^2.0.1",
    "astro": "^5.17.1",
    "astro-embed": "^0.9.0",
    "astro-icon": "^1.1.5",
    "astro-navbar": "^2.4.0",
    "exceljs": "^4.4.0",
    "gsap": "^3.14.2",
    "limax": "4.1.0",
    "lodash.merge": "^4.6.2",
    "matter-js": "^0.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "unpic": "^4.1.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.2",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/partytown": "^2.1.4",
    "@astrojs/tailwind": "^6.0.2",
    "@eslint/js": "^9.33.0",
    "@google-cloud/storage": "^7.19.0",
    "@iconify-json/flat-color-icons": "^1.2.1",
    "@iconify-json/tabler": "^1.2.20",
    "@tailwindcss/typography": "^0.5.16",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/mdx": "^2.0.13",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "astro-compress": "2.3.8",
    "astro-eslint-parser": "^1.2.2",
    "eslint": "^9.33.0",
    "eslint-plugin-astro": "^1.3.1",
    "globals": "^16.3.0",
    "js-yaml": "^4.1.0",
    "mdast-util-to-string": "^4.0.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "reading-time": "^1.5.0",
    "sharp": "0.34.3",
    "svgo": "^4.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.39.0",
    "unist-util-visit": "^5.0.0"
  }
}
