{
  "name": "@onwidget/astrowind",
  "version": "1.0.0-beta.52",
  "description": "AstroWind: A free template using Astro 5.0 and Tailwind CSS. Astro starter theme.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "overrides": {
    "astro-compress": {
      "sharp": "0.34.5"
    },
    "lodash": ">=4.17.23"
  },
  "pnpm": {
    "shamefullyHoist": true
  },
  "scripts": {
    "init": "bash scripts/init.sh",
    "dev": "export NODE_OPTIONS='--no-deprecation' && node scripts/ensure-contract-dev.js && astro dev",
    "start": "export NODE_OPTIONS='--no-deprecation' && node scripts/ensure-contract-dev.js && astro dev",
    "build": "npm update && node scripts/build-safe.js",
    "build:fast": "node scripts/build-safe.js",
    "preview": "NODE_OPTIONS='--no-deprecation' astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run check:astro && npm run check:eslint && npm run check:prettier",
    "check:astro": "NODE_OPTIONS='--no-deprecation' astro check",
    "check:eslint": "eslint .",
    "check:prettier": "prettier --check .",
    "fix": "npm run fix:eslint && npm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier -w .",
    "generate:favicons": "node scripts/generate-favicons.cjs",
    "upload:assets": "node scripts/upload-to-gcs.js",
    "upload:assets:dry": "node scripts/upload-to-gcs.js --dry-run",
    "check:gcs": "bash scripts/check-gcs-setup.sh",
    "check:full": "bash scripts/full-check.sh",
    "reconnect:gcs": "bash scripts/reconnect-gcs-buckets.sh",
    "reconnect:gcs:dry": "bash scripts/reconnect-gcs-buckets.sh --dry-run",
    "reconnect:cloudsql": "bash directus/reconnect-cloudsql.sh",
    "upload:optimized": "node scripts/upload-optimized-to-gcs.js",
    "cleanup:dist": "node scripts/cleanup-dist-public.js",
    "deploy:ssh-setup": "bash scripts/deploy-ssh-setup.sh",
    "push:ssh": "bash scripts/deploy-ssh-push.sh",
    "push:ssh:dry": "bash scripts/deploy-ssh-push.sh --dry-run",
    "push:ftp": "node scripts/deploy-ftp-push.js",
    "push:nginx": "node scripts/deploy-ftp-nginx.js",
    "push:ftp:dry": "node scripts/deploy-ftp-push.js --dry-run",
    "build:gcs": "npm run check:gcs && ALLOW_PRIVATE_UPLOADS=true npm run upload:assets && npm run optimize:directus-images && npm run build && npm run upload:optimized && npm run cleanup:dist && npm run push:ftp",
    "deploy": "node scripts/deploy-with-progress.js",
    "deploy:direct": "npm run build:gcs",
    "migrate:wp": "node scripts/migrate-wp-to-directus.js",
    "migrate:wp:dry": "node scripts/migrate-wp-to-directus.js --dry-run",
    "migrate:wp:db": "node scripts/migrate-wp-to-directus.js --db-fallback",
    "backfill:images": "node scripts/backfill-directus-images.js",
    "backfill:images:dry": "node scripts/backfill-directus-images.js --dry-run",
    "optimize:directus-images": "node scripts/optimize-directus-images.js",
    "optimize:directus-images:dry": "node scripts/optimize-directus-images.js --dry-run",
    "optimize:directus-images:all": "node scripts/optimize-directus-images.js --all",
    "warm:image-proxy": "node scripts/warm-directus-image-proxy.js",
    "warm:image-proxy:dry": "node scripts/warm-directus-image-proxy.js --dry-run",
    "run:directus": "node scripts/run-directus.js",
    "run:directus:deploy": "node scripts/run-directus.js --deploy",
    "directus:schema": "node scripts/directus-schema-updates.js",
    "directus:schema:dry": "node scripts/directus-schema-updates.js --dry-run",
    "fix:content-column": "node scripts/fix-directus-content-column.js",
    "contract:docx-to-md": "node scripts/docx-to-contract-md.js",
    "contract:reprocess-mdx": "node scripts/reprocess-contract-mdx.js",
    "contract:fix-indent": "sh scripts/contract-fix-indent.sh",
    "contract:clean": "npm run contract:reprocess-mdx -- --fix-malformed",
    "contract:reprocess-mdx:dry": "node scripts/reprocess-contract-mdx.js --dry-run",
    "contract:reprocess-mdx:fix": "node scripts/reprocess-contract-mdx.js --fix-malformed",
    "contract:docx-to-mdx": "node scripts/docx-to-contract-mdx.js",
    "contract:verify-indents": "node scripts/verify-contract-indents.js",
    "debug:content-field": "node scripts/debug-directus-content-field.js",
    "campaign-posters": ".venv/bin/python scripts/upload-campaign-posters-to-directus.py",
    "campaign-posters:dry": ".venv/bin/python scripts/upload-campaign-posters-to-directus.py --dry-run"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@astrolib/analytics": "^0.6.1",
    "@astrolib/seo": "^1.0.0-beta.8",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@mdxeditor/editor": "^3.52.4",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "array-iterate": "^2.0.1",
    "astro": "^5.18.0",
    "astro-embed": "^0.12.0",
    "astro-icon": "^1.1.5",
    "astro-navbar": "^2.4.0",
    "basic-ftp": "^5.2.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "exceljs": "^4.4.0",
    "gsap": "^3.14.2",
    "isomorphic-dompurify": "^3.0.0-rc.2",
    "limax": "4.2.2",
    "lodash.merge": "^4.6.2",
    "matter-js": "^0.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "unpic": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/partytown": "^2.1.4",
    "@astrojs/tailwind": "^6.0.2",
    "@eslint/js": "^9.39.2",
    "@google-cloud/storage": "^7.19.0",
    "@iconify-json/flat-color-icons": "^1.2.3",
    "@iconify-json/tabler": "^1.2.26",
    "@tailwindcss/typography": "^0.5.19",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/matter-js": "^0.20.2",
    "@types/mdx": "^2.0.13",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "astro-compress": "2.3.9",
    "astro-eslint-parser": "^1.2.2",
    "astro-pagefind": "^1.8.5",
    "eslint": "^9.39.2",
    "eslint-plugin-astro": "^1.5.0",
    "globals": "^17.4.0",
    "js-yaml": "^4.1.1",
    "mammoth": "^1.11.0",
    "mdast-util-to-string": "^4.0.0",
    "pg": "^8.13.1",
    "playwright": "^1.58.2",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "reading-time": "^1.5.0",
    "sharp": "0.34.5",
    "svgo": "^4.0.0",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "^3.4.19",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "unist-util-visit": "^5.1.0",
    "vitest": "^4.0.18"
  }
}
