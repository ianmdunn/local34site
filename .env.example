# Local 34 site – environment variables
# Copy to .env and fill in values. Never commit .env.

# -----------------------------------------------------------------------------
# Directus CMS
# -----------------------------------------------------------------------------
PUBLIC_DIRECTUS_URL=https://your-directus-instance.run.app
PUBLIC_DIRECTUS_IMAGE_PROXY_URL=
# DIRECTUS_TOKEN=  (server-only; never use PUBLIC_ or VITE_ prefix)
#   Required for: backfill:images, optimize:directus-images (admin token with files write)

# -----------------------------------------------------------------------------
# GCS / Assets
# -----------------------------------------------------------------------------
GCS_BUCKET_NAME=local34site-assetfiles
GCS_BUCKET_URL=
GOOGLE_APPLICATION_CREDENTIALS=

# -----------------------------------------------------------------------------
# Deployment (FTP)
# -----------------------------------------------------------------------------
# DEPLOY_FTP_HOST=
# DEPLOY_FTP_USER=
# DEPLOY_FTP_PASSWORD=
# DEPLOY_PATH=
# DEPLOY_FTP_PORT=21
# DEPLOY_FTP_SECURE=false

# -----------------------------------------------------------------------------
# Deployment (SSH)
# -----------------------------------------------------------------------------
# DEPLOY_SSH_HOST=
# DEPLOY_SSH_USER=
# DEPLOY_SSH_PORT=22
# DEPLOY_SSH_KEY=
# DEPLOY_SSH_PASSWORD=  (optional, for key install)
# DEPLOY_PATH=

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# PUBLIC_RSVP_ERROR_WEBHOOK_URL=  (POST when RSVP submit fails; e.g. Zapier, Make)
# PUBLIC_LEADERBOARD_API=
# LEADERBOARD_BUCKET_NAME=
# CONTRACT_READER_BUILD=true  (for contract-only builds)
# L34_EBOARD_XLSX_PATH=  (path to eboard Excel file)
