---
/**
 * Standalone tool layout – no site layout, nav, or chrome.
 * Used for /timer-popup only. Outputs minimal self-contained HTML.
 */
import Analytics from '~/components/common/Analytics.astro';

export interface Props {
  title?: string;
}

const { title = 'Timer' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <Analytics />
    <slot name="head" />
  </head>
  <body style="margin:0;min-height:100vh;min-height:100dvh;display:flex;flex-direction:column;background:transparent">
    <slot />
  </body>
</html>
