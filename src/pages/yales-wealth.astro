---
/**
 * Yale's Wealth – Local 34
 *
 * Endowment billboard + unified "The Reality" card (tax excuse + wage calculator).
 * Islands: YaleWealthProjectedReturns, YaleWealthCalculator (client:visible).
 */
import PageLayout from '~/layouts/PageLayout.astro';
import YaleWealthCalculator from '~/components/islands/YaleWealthCalculator.jsx';
import YaleWealthBillboard from '~/components/islands/YaleWealthBillboard.jsx';
import YaleWealthCardsAnim from '~/components/islands/YaleWealthCardsAnim.jsx';
import DollarSignTrigger from '~/components/islands/DollarSignTrigger.jsx';
import CatchTheCash from '~/components/islands/CatchTheCash.jsx';
import GameLaunchButton from '~/components/islands/GameLaunchButton.jsx';
import type { MetaData } from '~/types';
import { PAGE_SECTION_CLASS } from '~/lib/layout';
import weCantKeepUp from '~/assets/images/backgrounds/WeCantKeepUp.jpg';
import '~/components/islands/yale-wealth.css';

const PAGE = {
  title: "Yale's Wealth",
  description:
    "Yale's endowment gains millions every day while we fight to keep up. We're united to win a great contract!",
} as const;

const metadata: MetaData = {
  title: PAGE.title,
  description: PAGE.description,
};

const SECTION_IDS = {
  endowment: 'yale-endowment',
  reality: 'the-reality',
} as const;

const VERIFY_YALE_URL = 'https://president.yale.edu/posts/2025-07-03-update-on-tax-legislation';
---

<PageLayout metadata={metadata}>
  <div class="yale-wealth-page" style={`--yale-wealth-bg-url: url(${weCantKeepUp.src})`}>
    <section class="yale-wealth-header-section">
      <div class="page-container">
        <h1 class="yale-wealth-header__title">{PAGE.title}</h1>
        {PAGE.description && <p class="yale-wealth-header__desc">{PAGE.description}</p>}
      </div>
    </section>

    <!-- 1. Endowment billboard: GSAP entrance + count-up (bills are full-page layer) -->
    <section
      class={`yale-wealth-endowment-section yale-wealth-billboard ${PAGE_SECTION_CLASS}`}
      id={SECTION_IDS.endowment}
    >
      <div class="yale-wealth-billboard__overlay" aria-hidden="true"></div>
      <div class="yale-wealth-content yale-wealth-billboard__inner">
        <YaleWealthBillboard client:visible />
      </div>
      <DollarSignTrigger client:load />
    </section>

    <!-- 2. The Reality – editorial narrative, no card -->
    <section class={`yale-wealth-reality ${PAGE_SECTION_CLASS}`} id={SECTION_IDS.reality}>
      <article class="yale-wealth-reality__article">
        <header class="yale-wealth-reality__header">
          <h2 class="yale-wealth-reality__title" id="reality-heading">The Reality</h2>
          <a href={VERIFY_YALE_URL} target="_blank" rel="noopener" class="yale-wealth-reality__source" aria-label="Read Yale's statement on the tax">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </header>

        <p class="yale-wealth-reality__lead">
          When Yale announces cuts, it points to the tax. <strong>The reality: <span class="yale-wealth-reality__lead-tax">30 days is taxed</span>, the other 335 days of gains—not taxed.</strong>
        </p>
        <div class="yale-wealth-reality__timeline" role="img" aria-labelledby="reality-heading" aria-label="Bar: 30 days tax $300 million, 335 days gains $3.6 billion">
          <p class="yale-wealth-reality__timeline-caption" aria-hidden="true">One year</p>
          <div class="yale-wealth-reality__days">
            <div class="yale-wealth-reality__days-row">
              {[
                { flex: 30, tax: true },
                ...Array.from({ length: 11 }, () => ({ flex: 335 / 11, tax: false })),
              ].map((m, i) => (
                <span
                  class={`yale-wealth-reality__day yale-wealth-reality__day--${m.tax ? 'tax' : 'gains'}`}
                  style={`--day-i: ${i}; flex: ${m.flex} 1 0`}
                  title={m.tax ? 'Tax paid' : 'Untaxed gains'}
                />
              ))}
            </div>
            <span class="yale-wealth-reality__days-label yale-wealth-reality__days-label--tax">$300M</span>
            <span class="yale-wealth-reality__days-label yale-wealth-reality__days-label--gains">$3,600,000,000</span>
          </div>
          <p class="yale-wealth-reality__days-legend">
            <span class="yale-wealth-reality__days-legend-tax">30 days = tax</span>
            <span class="yale-wealth-reality__days-legend-gains">335 days = gains</span>
          </p>
        </div>
        <p class="yale-wealth-reality__body">
          The tax is 8% on <strong>gains</strong> only—not on the endowment itself. So when Yale says it can&apos;t afford a fair contract, remember this chart.
        </p>

        <p class="yale-wealth-reality__bridge">Meanwhile, our pay isn&apos;t keeping up.</p>

        <div class="yale-wealth-reality__wages">
          <div class="yale-wealth-reality__wages-header">
            <h3 class="yale-wealth-reality__wages-title">2026 Yale Minimum Rates by Labor Grade</h3>
            <a
              href="https://your.yale.edu/working-at-yale/careers/wage-ranges"
              target="_blank"
              rel="noopener"
              class="yale-wealth-reality__wages-source"
              aria-label="Minimum rate source"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden>
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </svg>
            </a>
          </div>
          <YaleWealthCalculator client:visible />
        </div>

        <p class="yale-wealth-reality__close">
          We shouldn&apos;t have to tighten our belts while Yale&apos;s endowment grows. When it comes to our contract, we won&apos;t let them cry poor.
        </p>
      </article>
    </section>
    <YaleWealthCardsAnim client:visible />
    <GameLaunchButton client:load />
    <CatchTheCash client:idle />
  </div>
</PageLayout>

