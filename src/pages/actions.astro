---
/**
 * Actions page (/actions)
 *
 * Unified layout: upcoming events + meeting tools (Zoom backgrounds, profile images).
 */
import PageLayout from '~/layouts/PageLayout.astro';
import { PAGE_SECTION_CLASS } from '~/lib/layout';
import ActionsComponent from '~/components/Actions.jsx';
import { getAsset } from '~/utils/permalinks';
import { fetchUpcomingActionEvents } from '~/utils/directus-events';
import { hydrateEventsWithJotformSchemas } from '~/utils/jotform';
import { generateOpenGraphMeta } from '~/utils/seo';

const directusEvents = await fetchUpcomingActionEvents(3);
const upcomingEvents = await hydrateEventsWithJotformSchemas(directusEvents);

const portalCarouselImages = [
  /* We Can't Keep Up */
  getAsset("zoom-backgrounds/Zoom Background - We Can't Keep Up.jpg"),
  getAsset("zoom-backgrounds/Zoom Background - We Can't Keep Up - Image.jpg"),
  getAsset("zoom-backgrounds/Zoom Background - We Can't Keep Up - Grid.jpg"),
  getAsset("zoom-backgrounds/Zoom Background - We Can't Keep Up - Button.jpg"),
  getAsset("zoom-backgrounds/Zoom Background - We Can't Keep Up - Button Only.jpg"),
  /* Union Strong */
  getAsset('zoom-backgrounds/Zoom Background - Union Strong.jpg'),
  getAsset('zoom-backgrounds/Zoom Background - Union Strong - Image.jpg'),
  getAsset('zoom-backgrounds/Zoom Background - Union Strong - Grid.jpg'),
  getAsset('zoom-backgrounds/Zoom Background - Union Strong - Button.jpg'),
  getAsset('zoom-backgrounds/Zoom Background - Union Strong - Button Only.jpg'),
  /* We're Worth It (curly apostrophe in actual filename) */
  getAsset("zoom-backgrounds/Zoom Background - We\u2019re Worth It!.jpg"),
  getAsset("zoom-backgrounds/Zoom Background - We're Worth It - Image.jpg"),
  getAsset("zoom-backgrounds/Zoom Background - We're Worth It - Grid.jpg"),
  getAsset("zoom-backgrounds/Zoom Background - We're Worth It - Button.jpg"),
  getAsset("zoom-backgrounds/Zoom Background - We're Worth It - Button Only.jpg"),
  /* United for a Great Contract */
  getAsset('zoom-backgrounds/Zoom Background - United for a Great Contract.jpg'),
  getAsset('zoom-backgrounds/Zoom Background - United for a Great Contract - Image.jpg'),
  getAsset('zoom-backgrounds/Zoom Background - United for a Great Contract - Grid.jpg'),
  /* Yale Can Afford It */
  getAsset('zoom-backgrounds/Zoom Background - Yale Can Afford It - Image.jpg'),
  getAsset('zoom-backgrounds/Zoom Background - Yale Can Afford It - Grid.jpg'),
  /* Repeat strong banner-filling images for longer loop */
  getAsset("zoom-backgrounds/Zoom Background - We Can't Keep Up - Image.jpg"),
  getAsset('zoom-backgrounds/Zoom Background - Union Strong - Image.jpg'),
  getAsset("zoom-backgrounds/Zoom Background - We're Worth It - Image.jpg"),
  getAsset('zoom-backgrounds/Zoom Background - United for a Great Contract - Image.jpg'),
  getAsset('zoom-backgrounds/Zoom Background - Yale Can Afford It - Image.jpg'),
];

const metadata = {
  title: 'Actions | Local 34',
  description: 'United for a Great Contract! Upcoming events and meeting visibility tools.',
  openGraph: generateOpenGraphMeta({
    images: [
      {
        url: getAsset('zoom-backgrounds/Zoom Background - United for a Great Contract - Image.jpg'),
        alt: 'United for a Great Contract campaign graphic',
      },
    ],
  }),
};
---

<PageLayout metadata={metadata}>
  <script slot="head" src="/scripts/form-guard.js" defer></script>
  <section class={PAGE_SECTION_CLASS} data-section="actions-hero" id="actions-hero">
    <div class="page-title-section relative max-w-7xl px-4 sm:px-6 lg:px-8 text-left">
      <h1
        class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tighter tracking-tighter mb-4 font-heading text-gray-900 dark:text-white"
      >
        United for a Great Contract!
      </h1>
    </div>
  </section>

  <section class={PAGE_SECTION_CLASS} data-section="actions-content" id="actions-content">
    <div class="mx-auto max-w-7xl w-full px-4 sm:px-6 lg:px-8">
      <ActionsComponent
        client:visible
        upcomingEvents={upcomingEvents}
        backgroundsHref="/meeting-backgrounds"
        backgroundsPortalImages={portalCarouselImages}
      />
    </div>
  </section>
</PageLayout>
