---
/**
 * Homepage (/)
 *
 * Content source: sitePages/home.md (local).
 *
 * Sections (in order):
 * 1. HomeHero – full-viewport hero with background image, headline, primary actions, and get-involved CTA
 * 2. WhoWeAreSection – value props (fair wages, stronger together, who we represent)
 */
import PageLayout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Button from '~/components/ui/Button.astro';
import { SITE } from 'astrowind:config';
import { getPermalink, getAsset } from '~/utils/permalinks';
import { getCollection } from 'astro:content';
import Features3 from '~/components/widgets/Features3.astro';

// Hero background images from public/hero-backgrounds/ – served from GCS when GCS_ENABLED
const HERO_BG_PATHS = [
  'hero-backgrounds/L34pick_-01.jpg',
  'hero-backgrounds/L34pick_-02.jpg',
  'hero-backgrounds/L34pick_-04.jpg',
  'hero-backgrounds/L34pick_-05.jpg',
  'hero-backgrounds/L34pick_-06.jpg',
  'hero-backgrounds/L34pick_-07.jpg',
  'hero-backgrounds/L34pick_-08.jpg',
  'hero-backgrounds/L34pick_-09.jpg',
  'hero-backgrounds/L34pick_-10.jpg',
  'hero-backgrounds/L34pick_-11.jpg',
  'hero-backgrounds/L34pick_-12.jpg',
];
const heroBgData = HERO_BG_PATHS.map((path) => ({ src: getAsset(path), srcset: '' }));
const heroBgInitialIndex = heroBgData.length > 0 ? Math.floor(Math.random() * heroBgData.length) : 0;

// Resolve home page content from local markdown (sitePages)
const sitePages = await getCollection('sitePages');
const homeEntry = sitePages.find((p) => p.slug === 'home');
const homeData = homeEntry?.data ?? { title: SITE.title, description: SITE.description };

const pageMetadata = {
  title: homeEntry ? homeEntry.data.title : SITE.title,
  description: homeEntry && 'description' in homeEntry.data ? homeEntry.data.description : SITE.description,
};

// Section 1: Hero (headline + background from backgrounds folder)
// Homepage title: line break + custom font for “UNITE HERE!”
const homeHeroTitleHtml =
  '<span class="hero-title-wrap"><span class="hero-title-line1">Local 34</span><br><span class="hero-title-unite">UNITE HERE!</span></span>';
const homeHero = {
  tagline: '',
  headline: homeData.title,
  headlineHtml: homeHeroTitleHtml,
  subtitle: 'description' in homeData ? (homeData.description ?? '') : '',
  primaryActions: undefined as import('~/types').CallToAction[] | undefined,
};
// CTA in hero (cover image)
const heroCta = {
  title: 'Ready to win a great contract?',
  subtitle: 'Join the campaign to win!',
  buttonText: 'Upcoming Events and Action',
  buttonHref: getPermalink('/actions'),
};
// Section 2: Who We Are (value props grid)
const HOME_SECTION_IDS = {
  hero: 'home-hero',
  whoWeAre: 'who-we-are',
} as const;
---

<PageLayout metadata={pageMetadata}>
  <Fragment slot="announcement"></Fragment>
  <Hero
    id={HOME_SECTION_IDS.hero}
    tagline={homeHero.tagline}
    title={homeHero.headlineHtml}
    subtitle={homeHero.subtitle}
    actions={homeHero.primaryActions}
  >
    {
      heroBgData[heroBgInitialIndex] && (
        <img
          id="home-hero-bg"
          slot="bg"
          src={heroBgData[heroBgInitialIndex].src}
          alt=""
          loading="eager"
          fetchpriority="high"
          decoding="async"
          class="absolute inset-0 w-full h-full min-w-full min-h-full object-cover object-[center_35%]"
        />
      )
    }
    <div slot="content" class="mt-14 md:mt-16 pt-10 md:pt-12 border-t border-white/20 border-solid">
      <p class="text-xl font-semibold text-white mb-3">{heroCta.title}</p>
      <p class="text-base text-slate-200 mb-8 max-w-2xl mx-auto">{heroCta.subtitle}</p>
      <div class="flex justify-center">
        <Button variant="primary" text={heroCta.buttonText} href={heroCta.buttonHref} class="min-w-[11rem]" />
      </div>
    </div>
  </Hero>
  <Features3
    id={HOME_SECTION_IDS.whoWeAre}
    title="The Union of Clerical & Technical Workers at Yale"
    subtitle="Local 34-UNITE HERE represents over four thousand workers who make Yale University run. We fight for dignity and respect on the job and in our community."
  />
  <script define:vars={{ heroBgData }}>
    (function () {
      if (!heroBgData || heroBgData.length <= 1) return;
      var el = document.getElementById('home-hero-bg');
      if (!el) return;
      var i = Math.floor(Math.random() * heroBgData.length);
      var item = heroBgData[i];
      el.src = item.src;
      el.srcset = item.srcset || '';
    })();
  </script>
</PageLayout>
