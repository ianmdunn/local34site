---
import PageLayout from '~/layouts/PageLayout.astro';
import { getCanonical } from '~/utils/permalinks';

const title = `Error 404`;
---

<PageLayout metadata={{ title }}>
  <section class="flex items-center min-h-[60vh] p-16" data-section="404" id="404-page">
    <div class="page-container flex flex-col items-center justify-center my-8">
      <div class="max-w-md text-center">
        <h2 class="mb-8 font-bold text-9xl">
          <span class="sr-only">Error</span>
          <span class="text-primary">404</span>
        </h2>
        <p class="text-2xl font-semibold">Sorry, we couldn't find this page.</p>
        <a
          rel="noopener"
          href={String(getCanonical('/'))}
          class="btn ml-4 mt-4 inline-block rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary"
          data-cta="404_back_home">Back to homepage</a
        >
      </div>
    </div>
  </section>
</PageLayout>
