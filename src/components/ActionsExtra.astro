---
import Content from '~/components/widgets/Content.astro';
---

<Content
  id="meeting-visibility-tools"
  tagline="Meeting Visibility Tools"
  title="Click any image to download it directly to your device."
>
  <Fragment slot="content">
    <h2 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-3xl mb-4">
      Meeting Backgrounds
    </h2>
    <p class="mb-4">Setting Your Meeting Background</p>

    <h4 class="text-xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-2xl mb-2">ZOOM</h4>
    <ol class="list-decimal list-inside mb-4">
      <li>Download an image above.</li>
      <li>In a meeting, click the ^ next to Start Video.</li>
      <li>Choose Background & Effects.</li>
      <li>Click + to upload your file.</li>
    </ol>

    <h4 class="text-xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-2xl mb-2">MS TEAMS</h4>
    <ol class="list-decimal list-inside mb-4">
      <li>Download an image above.</li>
      <li>In a meeting, select More … Video effects.</li>
      <li>Click + Add new to upload.</li>
      <li>Click Apply to save.</li>
    </ol>

    <h2 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-3xl mb-4">
      Meeting Profile Icons
    </h2>
    <p class="mb-4">Camera-Off Solidarity</p>

    <h4 class="text-xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-2xl mb-2">WHY USE THESE?</h4>
    <p class="mb-4">
      These graphics ensure your support for the contract remains visible to management even when your camera is turned
      off during meetings.
    </p>

    <h4 class="text-xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-2xl mb-2">HOW TO SET</h4>
    <p class="mb-4">
      In Zoom or Teams account settings, select "Change Picture" or "Edit Profile" and upload your circular graphic.
    </p>
  </Fragment>
</Content>

<section class="py-12 md:py-16 lg:py-20 bg-gray-50 dark:bg-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
        Join us at these upcoming actions and meetings.
      </h2>
    </div>
    <div class="max-w-5xl mx-auto mt-10">
      <div class="bg-white dark:bg-page p-6 rounded-lg shadow-lg">
        <p class="text-lg font-semibold text-red-600 mb-2">FEB 24</p>
        <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Solidarity Summit</h3>
        <p class="text-gray-700 dark:text-gray-300 mb-2">⏰ Time: 5:30 PM (Doors 5:00 PM)</p>
        <p class="text-gray-700 dark:text-gray-300 mb-4">
          📍 Location: Trinity Temple C.O.G.I.C., 285 Dixwell Ave, New Haven, CT
        </p>
        <p class="text-gray-700 dark:text-gray-300 mb-4">
          Join New Haven Rising, Local 34, Local 33, Local 35, and community allies. We are coming together to demand a
          fair contract and a stronger community.
        </p>
        <h4 class="text-xl font-bold text-gray-900 dark:text-white mb-4">RSVP Directly Here ▼</h4>
        <form class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Name*</label>
            <div class="mt-1 grid grid-cols-2 gap-4">
              <input
                type="text"
                name="firstName"
                id="firstName"
                autocomplete="given-name"
                placeholder="First Name"
                class="block w-full shadow-sm sm:text-sm border-gray-300 rounded-md dark:bg-gray-700 dark:border-gray-600 dark:text-white"
              />
              <input
                type="text"
                name="lastName"
                id="lastName"
                autocomplete="family-name"
                placeholder="Last Name"
                class="block w-full shadow-sm sm:text-sm border-gray-300 rounded-md dark:bg-gray-700 dark:border-gray-600 dark:text-white"
              />
            </div>
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Email</label>
            <input
              type="email"
              name="email"
              id="email"
              autocomplete="email"
              class="mt-1 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md dark:bg-gray-700 dark:border-gray-600 dark:text-white"
            />
          </div>
          <div>
            <label for="phone" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Phone Number</label>
            <input
              type="tel"
              name="phone"
              id="phone"
              autocomplete="tel"
              class="mt-1 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md dark:bg-gray-700 dark:border-gray-600 dark:text-white"
            />
            <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
              By submitting your cell # and email, you are opting into mobile and email outreach from UNITE HERE! and
              its allies. Standard rates apply. Cancel at any time by replying STOP.
            </p>
          </div>
          <div>
            <label for="organization" class="block text-sm font-medium text-gray-700 dark:text-gray-300"
              >Organization</label
            >
            <select
              id="organization"
              name="organization"
              class="mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md dark:bg-gray-700 dark:border-gray-600 dark:text-white"
            >
              <option>Please Select</option>
              <option>New Haven Rising</option>
              <option>Local 34-UNITE HERE!</option>
              <option>Local 33 – UNITE HERE!</option>
              <option>Local 35 – UNITE HERE!</option>
              <option>Local 217 – UNITE HERE!</option>
              <option>SUN YURA</option>
              <option>Other</option>
            </select>
          </div>
          <div>
            <label for="otherOrganization" class="block text-sm font-medium text-gray-700 dark:text-gray-300"
              >What organization are you with?</label
            >
            <input
              type="text"
              name="otherOrganization"
              id="otherOrganization"
              class="mt-1 block w-full shadow-sm sm:text-sm border-gray-300 rounded-md dark:bg-gray-700 dark:border-gray-600 dark:text-white"
            />
          </div>
          <div>
            <button
              type="submit"
              class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500"
            >
              Submit RSVP
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
