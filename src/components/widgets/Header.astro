---
/**
 * Site header: astro-navbar (Astronav, MenuIcon, MenuItems, StickyHeader) with custom
 * drawer styling and full-page nav links.
 *
 * - Layout.astro owns toggle/close/scroll-lock and [data-nav-link] handling (capture phase,
 *   full page load). We do not use Astronav closeOnClick.
 * - Layout script sets nav.id = "main-nav" and menu button aria-controls for a11y.
 * - All nav links use data-nav-link, data-astro-reload, data-astro-prefetch="false".
 */
import { getCanonical } from '~/utils/permalinks';
import { headerData } from '~/navigation';
import { Astronav, MenuItems, MenuIcon, StickyHeader } from 'astro-navbar';

const { links } = headerData;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const firstLink = links[0];

function isCurrent(href: string): boolean {
  const path = href.replace(/^https?:\/\/[^/]+/, '').replace(/\/$/, '') || '/';
  return path === currentPath || currentPath.startsWith(path + '/');
}

const navLinkAttrs = {
  'data-astro-reload': true,
  'data-astro-prefetch': 'false' as const,
  'data-nav-link': true,
};
const liBaseClass = 'border-b border-gray-100 dark:border-slate-700/80 md:border-0 last:border-0 nav-drawer-li';
const firstLiClass = 'hidden md:list-item nav-drawer-first-li';
---

<header id="header" role="banner">
  <div class="nav-drawer-backdrop md:hidden" aria-hidden="true" data-nav-backdrop></div>
  <StickyHeader
    class="site-header sticky top-0 z-[100] flex-none w-full mx-auto bg-primary md:bg-primary dark:bg-primary dark:md:bg-primary backdrop-blur-sm"
    scrollY={60}
    defaultClass="pt-6 pb-4 md:py-4 border-transparent"
    activeClass="pt-6 pb-4 md:py-4 bg-primary md:bg-primary md:backdrop-blur-md site-header--scrolled"
  >
    <div class="page-container md:flex justify-between items-center">
      <Astronav>
        <div class="flex w-full md:w-auto justify-between items-center">
          <a
            class="flex items-center font-heading text-lg font-bold tracking-tight whitespace-nowrap text-white hover:text-white dark:hover:text-black focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-primary rounded transition-colors"
            href={String(getCanonical('/'))}
            data-astro-prefetch="false"
            data-nav-link
          >
            <span class="header-title-local">Local 34</span>-<span class="font-geometric">UNITE HERE!</span>
          </a>
          <div class="flex items-center md:hidden">
            <MenuIcon
              class="w-6 h-6 text-white flex flex-col justify-center items-center cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-primary rounded p-1 -mr-1"
            />
          </div>
        </div>
        <MenuItems
          class="hidden md:!flex items-center md:w-full md:h-auto md:flex-row md:justify-end md:self-center w-full"
          aria-label="Main navigation"
        >
          <div
            class="nav-drawer-header md:hidden flex items-center justify-between shrink-0 min-h-[2.75rem] px-3 py-0 border-b border-gray-100 dark:border-slate-700/80"
          >
            {
              firstLink ? (
                <a
                  href={firstLink.href}
                  {...navLinkAttrs}
                  class:list={[
                    'nav-drawer-home text-sm font-medium md:sr-only flex items-center min-h-[2.75rem] py-0 rounded-md transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset text-gray-800 hover:text-primary dark:text-slate-200 dark:hover:text-primary',
                    isCurrent(firstLink.href) && 'font-semibold text-primary dark:text-primary',
                  ]}
                  aria-current={isCurrent(firstLink.href) ? 'page' : undefined}
                >
                  {firstLink.text}
                </a>
              ) : null
            }
            <button
              type="button"
              data-nav-close
              aria-label="Close menu"
              class="nav-drawer-close-btn flex items-center justify-center gap-2 min-w-[2.75rem] min-h-[2.75rem] -mr-1 text-gray-600 hover:text-primary dark:text-slate-400 dark:hover:text-primary rounded-md hover:bg-gray-100 dark:hover:bg-slate-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-inset transition-colors ml-auto"
            >
              <span aria-hidden="true" class="flex flex-col justify-center items-center w-6 h-6">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M18 6L6 18M6 6l12 12"></path>
                </svg>
              </span>
              <span class="text-sm font-medium">Close</span>
            </button>
          </div>
          <ul
            class="flex flex-col md:flex-row md:gap-6 w-full md:w-auto pt-0 md:py-0 pb-4 md:pb-0 text-sm md:text-base font-medium nav-drawer-links md:!text-white"
            role="list"
          >
            {
              links.map((link, i) => {
                const isFirst = i === 0;
                const hasChildren = link.children && link.children.length > 0;
                const parentCurrent = isCurrent(link.href);
                const linkBaseClass =
                  'block px-3 py-4 md:px-0 md:py-0 md:inline-flex min-h-[4rem] items-center transition-colors duration-150 ease-in-out focus:outline-none focus-visible:ring-2 focus:ring-primary focus-visible:ring-inset rounded-md md:min-h-0 md:text-white md:hover:text-white dark:md:hover:text-black text-gray-800 hover:text-primary dark:text-slate-200 dark:hover:text-primary active:bg-gray-100 dark:active:bg-slate-800/80 md:active:bg-transparent';
                const currentClass = 'font-semibold text-primary dark:text-primary md:!text-white nav-link--current';
                if (hasChildren) {
                  const children = link.children!;
                  const childCurrent = children.some((c) => isCurrent(c.href));
                  const submenuId = `submenu-${i}-${link.text.toLowerCase().replace(/\s+/g, '-')}`;
                  return (
                    <li
                      class:list={[liBaseClass, isFirst && firstLiClass, 'dropdown']}
                      role="none"
                    >
                      <span class="inline-flex items-center md:flex md:w-full">
                        <a
                          href={link.href}
                          {...navLinkAttrs}
                          class:list={[linkBaseClass, (parentCurrent || childCurrent) && currentClass, 'inline-flex items-center gap-0.5']}
                          aria-current={parentCurrent ? 'page' : undefined}
                          aria-haspopup="true"
                          aria-expanded="false"
                          data-dropdown-trigger
                        >
                          {link.text}
                          <span class="hidden md:inline ml-0.5" aria-hidden="true">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                              <path d="M6 9l6 6 6-6" />
                            </svg>
                          </span>
                        </a>
                        <button
                          type="button"
                          class="nav-submenu-toggle md:!hidden"
                          aria-label={`Toggle ${link.text} submenu`}
                          aria-expanded="false"
                          aria-controls={submenuId}
                          data-nav-submenu-toggle
                          data-no-nav-close
                        >
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M6 9l6 6 6-6" />
                          </svg>
                        </button>
                      </span>
                      <!-- Desktop: drawer same width as this menu item only -->
                      <div class="dropdown-menu hidden md:!block" role="list" aria-label={`${link.text} submenu`}>
                        <div class="nav-chips-wrap">
                          {children.map((child) => {
                            const cur = isCurrent(child.href);
                            return (
                              <a
                                href={child.href}
                                {...navLinkAttrs}
                                class:list={['nav-chip', cur && 'nav-chip--current']}
                                aria-current={cur ? 'page' : undefined}
                              >
                                {child.text}
                              </a>
                            );
                          })}
                        </div>
                      </div>
                      <!-- Mobile: sliding panel (chips slide out to left) -->
                      <div
                        id={submenuId}
                        class="nav-submenu-panel md:hidden"
                        role="dialog"
                        aria-label={`${link.text} submenu`}
                        aria-hidden="true"
                      >
                        <button
                          type="button"
                          class="nav-submenu-back"
                          aria-label="Back to menu"
                          data-nav-submenu-back
                        >
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M19 12H5M12 19l-7-7 7-7" />
                          </svg>
                          Back
                        </button>
                        <ul class="nav-submenu-panel-list" role="list">
                          {children.map((child) => {
                            const cur = isCurrent(child.href);
                            return (
                              <li role="none">
                                <a
                                  href={child.href}
                                  {...navLinkAttrs}
                                  class:list={[linkBaseClass, 'min-h-[2.75rem]', cur && currentClass]}
                                  aria-current={cur ? 'page' : undefined}
                                >
                                  {child.text}
                                </a>
                              </li>
                            );
                          })}
                        </ul>
                      </div>
                    </li>
                  );
                }
                return (
                  <li class:list={[liBaseClass, isFirst && firstLiClass]} role="none">
                    <a
                      href={link.href}
                      {...navLinkAttrs}
                      class:list={[linkBaseClass, parentCurrent && currentClass]}
                      aria-current={parentCurrent ? 'page' : undefined}
                    >
                      {link.text}
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </MenuItems>
      </Astronav>
    </div>
  </StickyHeader>
</header>
