---
import { getEboardFromXlsx } from '~/lib/eboard';

const { officersAndStaff, executiveBoard } = await getEboardFromXlsx();
---

<section class="py-8 md:py-10 bg-gray-50 dark:bg-gray-900/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-white text-center mb-6">
      Local 34 Officers & Staff
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5 max-w-5xl mx-auto w-full">
      {
        officersAndStaff.map((person) => (
          <div class="text-center md:text-left py-0.5">
            <p class="font-semibold text-gray-900 dark:text-white text-sm">{person.name}</p>
            <p class="text-gray-600 dark:text-gray-400 text-xs mt-0">{person.title}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<section class="py-10 md:py-12 lg:py-14">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-gray-900 dark:text-white text-center mb-6">
      Executive Board
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 max-w-5xl mx-auto w-full">
      {
        executiveBoard.map((person) => (
          <div class="text-center sm:text-left py-0.5">
            <p class="font-semibold text-gray-900 dark:text-white text-sm">{person.name}</p>
            <p class="text-gray-600 dark:text-gray-400 text-xs mt-0">{person.area}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
