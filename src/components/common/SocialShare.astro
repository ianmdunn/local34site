---
export interface Props {
  text: string;
  url: string | URL;
  class?: string;
}

const { text, url, class: className = 'inline-block' } = Astro.props;
---

const socialNetworks = [
  { name: 'X', network: 'twitter', label: 'Share on X (Twitter)' },
  { name: 'Facebook', network: 'facebook', label: 'Share on Facebook' },
  { name: 'LinkedIn', network: 'linkedin', label: 'Share on LinkedIn' },
  { name: 'WhatsApp', network: 'whatsapp', label: 'Share on WhatsApp' },
  { name: 'Email', network: 'mail', label: 'Share by email' },
];
---

<div class={className}>
  <span class="align-super font-bold text-slate-500 dark:text-slate-400">Share:</span>
  {socialNetworks.map((social) => (
    <button
      type="button"
      class="ml-2 rtl:ml-0 rtl:mr-2 text-sm text-gray-500 dark:text-slate-400 hover:text-black dark:hover:text-slate-300 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 rounded"
      aria-label={social.label}
      data-aw-social-share={social.network}
      data-aw-url={url}
      data-aw-text={text}
    >{social.name}</button>
  ))}
