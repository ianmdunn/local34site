---
import { getAsset, getCanonicalBaseHref, getCanonicalOrigin } from '~/utils/permalinks';

const canonicalOrigin = getCanonicalOrigin();
const canonicalBaseHref = getCanonicalBaseHref();
// In dev, use dev origin but same base path so relative URLs and assets resolve correctly
const baseHref = import.meta.env.DEV
  ? Astro.url.origin + canonicalBaseHref.slice(canonicalOrigin.length)
  : canonicalBaseHref;
const isDev = import.meta.env.DEV;
---

<!-- In production only: if we're on www, send user to the same page on non-www. In dev, never redirect (e.g. localhost). -->
<script is:inline define:vars={{ canonicalOrigin, baseHref, isDev }}>
  (function () {
    if (isDev) return;
    var canonicalHost = new URL(canonicalOrigin).hostname;
    var onWww = location.hostname.startsWith('www.');
    if (!onWww || location.hostname !== 'www.' + canonicalHost) return;
    var intended = canonicalOrigin + location.pathname + location.search + location.hash;
    location.replace(intended);
  })();
</script>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<base href={baseHref} />
<link rel="sitemap" href={getAsset('/sitemap-index.xml')} />
