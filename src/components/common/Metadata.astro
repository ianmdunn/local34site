---
import merge from 'lodash.merge';
import { AstroSeo } from '@astrolib/seo';

import type { Props as AstroSeoProps } from '@astrolib/seo';

import { SITE, METADATA, I18N } from 'astrowind:config';
import type { MetaData } from '~/types';
import { getCanonical, getCanonicalBaseHref } from '~/utils/permalinks';

import { adaptOpenGraphImages } from '~/utils/images';

export interface Props extends MetaData {
  dontUseTitleTemplate?: boolean;
}

const {
  title,
  ignoreTitleTemplate = false,
  canonical = String(getCanonical(String(Astro.url.pathname))),
  robots = {},
  description,
  openGraph = {},
  twitter = {},
} = Astro.props;

const defaultSeoProps: AstroSeoProps = {
  title: METADATA?.title?.default ?? '',
  titleTemplate: METADATA?.title?.template ?? '%s',
  canonical: canonical,
  noindex: METADATA?.robots?.index === false,
  nofollow: METADATA?.robots?.follow === false,
  description: METADATA?.description,
  openGraph: {
    url: canonical,
    site_name: SITE?.name,
    images: [],
    locale: I18N?.language || 'en',
    type: 'website',
    ...METADATA?.openGraph,
  },
  twitter: {
    ...METADATA?.twitter,
  },
};

const pageSeoProps: AstroSeoProps = {
  title: title,
  titleTemplate: ignoreTitleTemplate ? '%s' : undefined,
  canonical: canonical,
  noindex: robots?.index === false,
  nofollow: robots?.follow === false,
  description: description,
  openGraph: { url: canonical, ...openGraph },
  twitter: twitter,
};

const seoProps: AstroSeoProps = merge(defaultSeoProps, pageSeoProps);

// Ensure the site always has a document title (browser tab, bookmarks, SEO)
const siteTitle = METADATA?.title?.default ?? SITE?.name ?? 'Local 34-UNITE HERE!';
if (!seoProps.title?.trim()) {
  seoProps.title = siteTitle;
}

const optimizedOpenGraph = await adaptOpenGraphImages(seoProps?.openGraph, new URL(getCanonicalBaseHref()));
const primaryOpenGraphImage = optimizedOpenGraph?.images?.find((image) => typeof image?.url === 'string' && image.url.trim());
const twitterCardType = seoProps.twitter?.cardType || (primaryOpenGraphImage ? 'summary_large_image' : 'summary');

const twitterFallbackMetaTags: Array<{ name: string; content: string }> = [];
if (seoProps.title) {
  twitterFallbackMetaTags.push({ name: 'twitter:title', content: seoProps.title });
}
if (seoProps.description) {
  twitterFallbackMetaTags.push({ name: 'twitter:description', content: seoProps.description });
}
if (primaryOpenGraphImage?.url) {
  twitterFallbackMetaTags.push({ name: 'twitter:image', content: primaryOpenGraphImage.url });
}

const seoOutput: AstroSeoProps = {
  ...seoProps,
  openGraph: optimizedOpenGraph,
  twitter: {
    ...seoProps.twitter,
    cardType: twitterCardType,
  },
  additionalMetaTags: [...(seoProps.additionalMetaTags || []), ...twitterFallbackMetaTags],
};

// JSON-LD Organization schema for SEO
const canonicalOrigin = new URL(getCanonicalBaseHref()).origin;
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE?.name ?? 'Local 34-UNITE HERE!',
  url: canonicalOrigin,
  description: METADATA?.description ?? 'The Union of Clerical & Technical Workers at Yale.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '425 College Street, 2nd Floor',
    addressLocality: 'New Haven',
    addressRegion: 'CT',
    postalCode: '06511',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+1-203-624-5161',
    contactType: 'customer service',
    email: '34@yaleunions.org',
  },
};
---

<AstroSeo {...seoOutput} />
<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
